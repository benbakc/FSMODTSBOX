                                    </StackPanel>
                                    <TextBlock Text="选择翻译引擎" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,12"/>
                                    <ComboBox x:Name="ProviderCombo" Background="{StaticResource BgInput}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderDefault}" Height="36" FontSize="12" Margin="0,0,0,10" SelectionChanged="ProviderCombo_SelectionChanged"/>
                                <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="0,4,0,12"/>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="SettingsLangIcon" Text="🌐" FontFamily="Segoe UI Emoji" FontSize="15" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="SettingsLangLabel" Text="界面语言" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="LangUISwitch" Background="{StaticResource BgInput}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderDefault}" Height="36" FontSize="12" Margin="0,10,0,0" SelectionChanged="LangUISwitch_SelectionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                            <Border Grid.Column="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🔑 API 密钥配置" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock x:Name="SettingsApiHintText" Text="配置你的翻译 API 密钥（留空则使用内置 Agnes 2.0 Flash）" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,16"/>
                                    <StackPanel x:Name="ApiKeyPanel">
                                        <TextBlock Text="API 密钥" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="OwnApiKeyBox"/>
                                    </StackPanel>
                                    <StackPanel x:Name="CustomPanel" Visibility="Collapsed">
                                        <TextBlock Text="自定义 URL" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="CustomUrlBox"/>
                                        <TextBlock Text="模型名称" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,4"/>
                                        <TextBox x:Name="CustomModelBox"/>
                                        <TextBlock Text="自定义 API 密钥" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,4"/>
                                        <TextBox x:Name="CustomApiKeyBox"/>
                                    </StackPanel>
                                    <Button Content="保存设置" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Padding="24,0" Margin="0,20,0,0" Click="SaveSettingsBtn_Click"/>
                                    <TextBlock x:Name="SettingsStatusText" FontSize="11" Foreground="{StaticResource Success}" Margin="0,8,0,0"/>
                                    <Border Margin="0,16,0,0" Padding="12" Background="#0d0d1a" BorderBrush="#353550" BorderThickness="1" CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Text="💡 提示" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="SettingsTipText" TextWrapping="Wrap" FontSize="10.5" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0">
                                                <Run Text="内置 Agnes 2.0 Flash 为免费共享模型，随着使用人数增多可能会变慢。"/>
                                                <LineBreak/>
                                                <Run Text="不同模型的能力和翻译速度也不一样，如果觉得内置模型不够理想，建议使用自己的 API 密钥选择其他模型。"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Button Grid.Column="3" Content="← 返回" Style="{StaticResource SecondaryButton}" VerticalAlignment="Bottom" Padding="16,6" Margin="0,0,0,4" Click="NavHome_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

        </Grid>

            <!-- BOTTOM STATUS BAR -->
            <Border Grid.Row="2" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource Success}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="BottomStatusText" FontSize="10.5" Foreground="{StaticResource TextMuted}" Margin="7,0,0,0" VerticalAlignment="Center">就绪</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="当前版本: v1.0.0" FontSize="10.5" Foreground="{StaticResource TextMuted}" Margin="0,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
